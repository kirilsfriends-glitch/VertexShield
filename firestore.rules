rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - email: string (optional)
    //   - role: string (required, enum: ['admin', 'moderator', 'user'])
    //   - isBanned: boolean (required)
    //   - isPremium: boolean (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: obfuscations
    // Document ID: {obfuscationId} (Auto-generated)
    // Fields:
    //   - userId: string (required, matches Auth UID)
    //   - sourceCode: string (required, max 1MB)
    //   - obfuscatedCode: string (required, max 1MB)
    //   - timestamp: timestamp (required)
    //   - name: string (required, max 100 chars)
    //   - language: string (optional)
    //   - level: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kirilsfriends@gmail.com" && request.auth.token.email_verified == true));
    }

    function isModerator() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }

    function hasRequiredUserFields(data) {
      return data.keys().hasAll(['uid', 'username', 'role', 'isBanned', 'isPremium']);
    }

    function isValidUser(data) {
      return hasRequiredUserFields(data) &&
        data.uid is string &&
        data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
        data.role in ['admin', 'moderator', 'user'] &&
        data.isBanned is bool &&
        data.isPremium is bool;
    }

    function hasRequiredObfuscationFields(data) {
      return data.keys().hasAll(['userId', 'sourceCode', 'obfuscatedCode', 'timestamp', 'name']);
    }

    function isValidObfuscation(data) {
      return hasRequiredObfuscationFields(data) &&
        data.userId == request.auth.uid &&
        data.sourceCode is string && data.sourceCode.size() < 1048576 &&
        data.obfuscatedCode is string && data.obfuscatedCode.size() < 1048576 &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins and Moderators can read any profile.
      allow read: if isOwner(userId) || isAdmin() || isModerator();
      
      // Profile creation: User can create their own profile as 'user' role. Admins can create any.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.isBanned == false) || 
        isAdmin()
      );
      
      // Profile update: User can update their own username. Admins/Moderators can update roles/bans.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.isBanned == resource.data.isBanned &&
         request.resource.data.uid == resource.data.uid) || 
        isAdmin() || 
        (isModerator() && request.resource.data.role == resource.data.role)
      );

      allow delete: if isAdmin();
    }

    match /obfuscations/{obfuscationId} {
      // Users can read their own obfuscations. Admins can read all.
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can create their own obfuscation records.
      allow create: if isAuthenticated() && isValidObfuscation(request.resource.data);
      
      // Obfuscations are generally immutable.
      allow update: if false;
      
      // Users can delete their own records.
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
